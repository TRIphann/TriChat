# =============================================================================
# TriChat — environment template
# Copy this file to `.env` at the repo root and fill in real values.
# `.env` is in .gitignore so secrets never leak.
#
# Compose:  `docker compose up --build` reads this file via env_file.
# Render:   paste each key/value into the service's "Environment" tab.
# VPS:      `export $(grep -v '^#' .env | xargs)` then `docker compose up`.
# =============================================================================

# ---- Firebase (Firestore + Auth + FCM) ----
# Get the JSON from Firebase Console > Project settings > Service accounts.
# Run scripts/encode-firebase-key.ps1 once to get the base64 string below.
FIREBASE_PROJECT_ID=trichat-xxxxx
FIREBASE_DATABASE_ID=
FIREBASE_CREDENTIALS_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Li4u

# ---- Redis ----
# Locally the compose service is "redis". On Render use the Upstash rediss:// URL.
REDIS_CONNECT_STRING=redis:6379

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Groq (AI moderation) ----
# Sign up at https://console.groq.com — free tier is enough for development.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# ---- Gmail SMTP (OTP emails) ----
# Use a Gmail App Password, NOT your real Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_16_chars
SMTP_FROM=your_email@gmail.com

# ---- CORS ----
# Comma-separated list of origins allowed by the backend.
# For local dev include the Flutter Web dev origin (Chrome hits http://localhost:xxxxx).
BACKEND_ALLOWED_ORIGINS=http://localhost:5244,http://localhost:3000,http://localhost:5000,https://your-firebase-hosting.web.app
