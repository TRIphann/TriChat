{
  "info": {
    "name": "Chat API - Zalo Clone",
    "description": "Complete chat system API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://localhost:7000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_FIREBASE_TOKEN",
      "type": "string"
    },
    {
      "key": "conversation_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "message_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Conversations",
      "item": [
        {
          "name": "Get All Conversations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations"]
            }
          }
        },
        {
          "name": "Get Conversation by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}"]
            }
          }
        },
        {
          "name": "Create Private Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"private\",\n  \"participant_ids\": [\"user_id_here\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/conversations",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations"]
            }
          }
        },
        {
          "name": "Create Group Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"group\",\n  \"participant_ids\": [\"user_2\", \"user_3\", \"user_4\"],\n  \"group_name\": \"My Awesome Group\",\n  \"group_avatar_url\": \"https://example.com/avatar.jpg\",\n  \"group_description\": \"This is a test group\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/conversations",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations"]
            }
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"group_name\": \"Updated Group Name\",\n  \"group_avatar_url\": \"https://example.com/new-avatar.jpg\",\n  \"group_description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/group",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "group"]
            }
          }
        },
        {
          "name": "Add Participants",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"user_ids\": [\"user_5\", \"user_6\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/participants",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "participants"]
            }
          }
        },
        {
          "name": "Remove Participant",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}/participants/user_id_to_remove",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}", "participants", "user_id_to_remove"]
            }
          }
        },
        {
          "name": "Delete Conversation",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "Get Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}/messages?limit=50",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}", "messages"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "beforeMessageId",
                  "value": "",
                  "disabled": true
                }
              ]
            }
          }
        },
        {
          "name": "Send Text Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"type\": \"text\",\n  \"content\": \"Hello! This is a test message.\",\n  \"reply_to_message_id\": null,\n  \"is_forwarded\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages"]
            }
          }
        },
        {
          "name": "Send Image Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"type\": \"image\",\n  \"content\": \"Check this out!\",\n  \"media_url\": \"https://example.com/image.jpg\",\n  \"thumbnail_url\": \"https://example.com/thumb.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages"]
            }
          }
        },
        {
          "name": "Send File Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"type\": \"file\",\n  \"content\": \"Document attached\",\n  \"media_url\": \"https://example.com/document.pdf\",\n  \"file_name\": \"document.pdf\",\n  \"file_size\": 1024000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages"]
            }
          }
        },
        {
          "name": "Reply to Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"type\": \"text\",\n  \"content\": \"This is a reply\",\n  \"reply_to_message_id\": \"{{message_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages"]
            }
          }
        },
        {
          "name": "Update Message",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message_id\": \"{{message_id}}\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"new_content\": \"Updated message content\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages"]
            }
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}/messages/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}", "messages", "{{message_id}}"]
            }
          }
        },
        {
          "name": "React to Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message_id\": \"{{message_id}}\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"emoji\": \"❤️\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/chat/messages/react",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "messages", "react"]
            }
          }
        },
        {
          "name": "Mark as Read",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}/messages/{{message_id}}/read",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}", "messages", "{{message_id}}", "read"]
            }
          }
        },
        {
          "name": "Mark as Delivered",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/chat/conversations/{{conversation_id}}/messages/{{message_id}}/delivered",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "conversations", "{{conversation_id}}", "messages", "{{message_id}}", "delivered"]
            }
          }
        }
      ]
    }
  ]
}
